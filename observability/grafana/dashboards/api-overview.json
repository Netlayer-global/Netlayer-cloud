{
  "title": "NetLayer API · Overview",
  "uid": "netlayer-api-overview",
  "tags": ["netlayer", "api"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "panels": [
    {
      "type": "stat",
      "title": "Up",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "targets": [{ "expr": "up{job=\"netlayer-api\"}", "refId": "A" }],
      "options": { "colorMode": "background" },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }
          ]
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Request rate (req/s)",
      "gridPos": { "h": 8, "w": 12, "x": 4, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{job=\"netlayer-api\"}[1m])) by (status)",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Latency (p50 / p95 / p99)",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 0 },
      "targets": [
        {
          "expr": "histogram_quantile(0.5,  sum(rate(http_request_duration_seconds_bucket{job=\"netlayer-api\"}[5m])) by (le))",
          "legendFormat": "p50", "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{job=\"netlayer-api\"}[5m])) by (le))",
          "legendFormat": "p95", "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket{job=\"netlayer-api\"}[5m])) by (le))",
          "legendFormat": "p99", "refId": "C"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "5xx error ratio",
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{job=\"netlayer-api\",status=~\"5..\"}[5m])) / sum(rate(http_requests_total{job=\"netlayer-api\"}[5m]))",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percentunit" } }
    },
    {
      "type": "logs",
      "title": "API logs (Loki)",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 14 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        { "expr": "{container=~\"netlayer-.*\"} |= \"\"", "refId": "A" }
      ]
    }
  ]
}
