NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:5173

# SQLite (dev). For Postgres set: postgresql://user:pass@host:5432/db
DATABASE_URL="file:./dev.db"

# Optional. Leave empty to disable Redis-backed features (idempotency, socket adapter)
REDIS_URL=""

# Generate strong random values in production
JWT_SECRET="change-me-min-16-chars"
JWT_REFRESH_SECRET="change-me-min-16-chars"
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Provider mock toggles (default: all true)
PROXMOX_MOCK_MODE=true
CLOUDFLARE_MOCK_MODE=true
GRAFANA_MOCK_MODE=true
ZABBIX_MOCK_MODE=true
EMAIL_MOCK_MODE=true
SMS_PROVIDER=mock

# Real provider creds (only when MOCK_MODE=false)
PROXMOX_HOST=
PROXMOX_NODE=pve
PROXMOX_TOKEN_ID=
PROXMOX_TOKEN_SECRET=

CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_DOMAIN=netlayer.com

GRAFANA_URL=
GRAFANA_API_KEY=
GRAFANA_DATASOURCE_ID=1

ZABBIX_URL=
ZABBIX_USER=Admin
ZABBIX_PASSWORD=

RESEND_API_KEY=
RESEND_FROM="NetLayer Cloud <noreply@netlayer.com>"

RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=

MSG91_API_KEY=
MSG91_SENDER=NETLYR

# Object Storage (MinIO / S3-compatible)
# Leave MINIO_ENDPOINT empty to use mock mode (in-process bucket store)
MINIO_MOCK_MODE=true
MINIO_ENDPOINT=
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_PREFIX=netlayer
MINIO_REGION=us-east-1

LOG_LEVEL=info
LOG_PRETTY=true
METRICS_ENABLED=true
IDEMPOTENCY_TTL_SECONDS=86400
