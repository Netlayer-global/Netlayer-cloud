// â”€â”€â”€ STATUS PAGE â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
model StatusIncident {
  id               String    @id @default(cuid())
  title            String
  status           String    @default("investigating")  // investigating | identified | monitoring | resolved
  impact           String    @default("minor")          // minor | major | critical | maintenance
