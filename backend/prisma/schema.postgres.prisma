// --- WEBHOOK SUBSCRIPTIONS ----------------------------------
model WebhookSubscription {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  url         String
  events      String   @default("[]")  // JSON: ["server.created", "server.deleted", ...] or ["*"]
  secret      String                   // hex secret for HMAC-SHA256 signing
  isActive    Boolean  @default(true)
  lastDeliveredAt DateTime?
  lastFailedAt    DateTime?
  failureCount    Int       @default(0)
  createdAt   DateTime @default(now())

  deliveries  WebhookDelivery[]

  @@index([userId])
}

model WebhookDelivery {
  id              String   @id @default(cuid())
  subscriptionId  String
  subscription    WebhookSubscription @relation(fields: [subscriptionId], references: [id])
  event           String
  payload         String   // JSON string
  status          String   @default("pending")  // pending | delivered | failed
  responseStatus  Int?
  responseBody    String?
  attempts        Int      @default(0)
  lastAttemptAt   DateTime?
  createdAt       DateTime @default(now())

  @@index([status, createdAt])
  @@index([subscriptionId])
}


// â”€â”€â”€ BLOG â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
model BlogPost {
