// â”€â”€â”€ IP POOLS (Round 18) â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
// SQLite stores arrays/JSON as JSON-encoded strings (see existing pattern).
// Allocator + admin pool management; FloatingIp / IpAddress reference pools.
model IpPool {
  id        String      @id @default(cuid())
  regionId  String
  region    Region      @relation(fields: [regionId], references: [id])
  cidr      String
  type      String      @default("public")   // public | private | floating
  gateway   String
  dns1      String      @default("8.8.8.8")
  dns2      String      @default("1.1.1.1")
  isActive  Boolean     @default(true)
  createdAt DateTime    @default(now())

  ips       IpAddress[]

  @@index([regionId])
}

model IpAddress {
  id         String    @id @default(cuid())
  poolId     String
  pool       IpPool    @relation(fields: [poolId], references: [id])
  ip         String    @unique
  status     String    @default("available")   // available | reserved | assigned
  serverId   String?
  server     Server?   @relation("ServerPrimaryIp", fields: [serverId], references: [id])
  assignedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([poolId, status])
}

// â”€â”€â”€ PROMO CODES (Round 18) â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
model PromoCode {
  id          String            @id @default(cuid())
  code        String            @unique
  type        String            @default("credit")    // credit | discount_pct
  amount      Float
  currency    String            @default("INR")
  usageLimit  Int               @default(100)
  usageCount  Int               @default(0)
  minTopup    Float             @default(0)
  expiresAt   DateTime?
  isActive    Boolean           @default(true)
  createdBy   String
  createdAt   DateTime          @default(now())

  redemptions PromoRedemption[]

  @@index([isActive, expiresAt])
}

model PromoRedemption {
  id        String    @id @default(cuid())
  promoId   String
  promo     PromoCode @relation(fields: [promoId], references: [id])
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  amount    Float
  createdAt DateTime  @default(now())

  @@unique([promoId, userId])
  @@index([userId])
}

// â”€â”€â”€ ISO IMAGES (Round 18) â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
model IsoImage {
  id          String   @id @default(cuid())
  name        String
  filename    String
  sizeBytes   BigInt   @default(0)
  nodeId      String?
  node        Node?    @relation(fields: [nodeId], references: [id])
  downloadUrl String?
  proxmoxTask String?
  status      String   @default("available")   // downloading | available | error
  isPublic    Boolean  @default(false)
  userId      String?                          // owner if private
  createdAt   DateTime @default(now())

  @@index([nodeId, status])
}

// â”€â”€â”€ FLOATING IPS (Round 18) â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
// Independent of IpAddress: floating IPs are user-owned and survive
// server lifecycle. They billed daily at â‚¹50/mo via floatingIpBilling job.
model FloatingIp {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  ip         String   @unique
  regionId   String
  region     Region   @relation(fields: [regionId], references: [id])
  serverId   String?
  server     Server?  @relation("ServerFloatingIps", fields: [serverId], references: [id])
  rdns       String?
  status     String   @default("unassigned")   // unassigned | assigned | releasing
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([userId])
  @@index([regionId])
  @@index([serverId])
}

// â”€â”€â”€ ALERT RULES (Round 18) â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
// User-defined rules; alertEvaluator cron evaluates them every 5min and
// fires email/sms/webhook with a 30min cooldown per rule.
model AlertRule {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  serverId    String?
  server      Server?   @relation("ServerAlertRules", fields: [serverId], references: [id])
  name        String
  metric      String    // cpu_percent | ram_percent | disk_percent | network_in | network_out
  condition   String    // gt | lt | eq
  threshold   Float
  duration    Int       @default(5)            // consecutive minutes before firing
  channels    String    @default("[]")         // JSON array: ["email","sms","webhook"]
  webhookUrl  String?
  isActive    Boolean   @default(true)
  lastFiredAt DateTime?
  createdAt   DateTime  @default(now())

  @@index([userId, isActive])
  @@index([serverId])
}

// â”€â”€â”€ WAITLIST (Round 18) â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
model WaitlistEntry {
  id        String   @id @default(cuid())
  email     String
  product   String                    // gpu | kubernetes | bare-metal
  source    String?                   // page or campaign that captured them
  createdAt DateTime @default(now())

  @@unique([email, product])
}

// â”€â”€â”€ STATUS SUBSCRIBERS (Round 18) â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
model StatusSubscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())
}


// â”€â”€â”€ INVOICE COUNTERS (Round 20) â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
// Sequential, gap-free numbering per fiscal year + document type.
// India GST mandates monotonic invoice numbers per FY for tax invoices and
// separate sequence for credit notes.
//
// Format: NL/2025-26/000001  (tax invoice)
//         CN/2025-26/000001  (credit note)
//
// Atomic increment via @@unique on (kind, fiscalYear) + Prisma transaction
// with row-locking (Postgres) or single-writer guarantee (SQLite).
model InvoiceCounter {
  id          String   @id @default(cuid())
  kind        String                          // 'invoice' | 'credit_note' | 'receipt'
  fiscalYear  String                          // '2025-26'
  current     Int      @default(0)
  prefix      String   @default("NL")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([kind, fiscalYear])
}

// â”€â”€â”€ CREDIT NOTES (Round 20) â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
// Issued when an invoice is refunded (full or partial). Linked to the
// originating invoice. Has its own sequential numbering ("CN/2025-26/000001").
model CreditNote {
  id              String   @id @default(cuid())
  creditNoteNumber String  @unique
  invoiceId       String
  invoice         Invoice  @relation("InvoiceCreditNotes", fields: [invoiceId], references: [id])
  userId          String
  user            User     @relation("UserCreditNotes", fields: [userId], references: [id])
  amount          Float
  tax             Float    @default(0)
  taxBreakdown    String?                     // JSON
  total           Float    @default(0)
  currency        String   @default("INR")
  reason          String                      // refund | adjustment | discount | error
  notes           String?
  issuedBy        String?                     // admin user id (nullable for system-issued)
  refundReference String?                     // razorpay refund id, stripe refund id, etc.
  pdfUrl          String?
  createdAt       DateTime @default(now())

  @@index([userId, createdAt])
  @@index([invoiceId])
}
