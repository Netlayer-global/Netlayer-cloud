  slug        String    @unique
  title       String
  excerpt     String
  content     String                              // Markdown
  cover       String?                             // optional hero image URL
  category    String    @default("engineering")   // engineering | product | guides | announcements
  authorName  String    @default("NetLayer Team")
  authorRole  String    @default("Engineering")
  readMinutes Int       @default(4)
  tags        String    @default("[]")            // JSON
