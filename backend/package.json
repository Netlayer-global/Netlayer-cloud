{
  "name": "netlayer-backend",
  "version": "1.0.0",
  "description": "NetLayer Cloud API",
  "main": "dist/index.js",
  "scripts": {
    "dev": "nodemon --exec ts-node src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "svc:auth": "ts-node src/services-runtime/auth.svc.ts",
    "svc:billing": "ts-node src/services-runtime/billing.svc.ts",
    "svc:compute": "ts-node src/services-runtime/compute.svc.ts",
    "svc:admin": "ts-node src/services-runtime/admin.svc.ts",
    "svc:worker": "ts-node src/services-runtime/worker.ts",
    "svc:all": "concurrently -k -n auth,bill,comp,adm,wrk -c blue,green,magenta,yellow,cyan \"npm:svc:auth\" \"npm:svc:billing\" \"npm:svc:compute\" \"npm:svc:admin\" \"npm:svc:worker\"",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:seed": "ts-node prisma/seed.ts",
    "db:studio": "prisma studio",
    "db:switch:sqlite": "ts-node scripts/switch-db.ts sqlite",
    "db:switch:postgres": "ts-node scripts/switch-db.ts postgres",
    "db:migrate:to-postgres": "ts-node prisma/migrate-sqlite-to-postgres.ts",
    "db:postgres:bootstrap": "ts-node scripts/bootstrap-postgres.ts",
    "db:seed:nodes": "ts-node scripts/seed-nodes.ts"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "5.22.0",
    "@socket.io/redis-adapter": "^8.3.0",
    "@types/multer": "^2.1.0",
    "axios": "1.7.9",
    "bcryptjs": "2.4.3",
    "bullmq": "^5.34.6",
    "cookie-parser": "1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "4.21.2",
    "express-rate-limit": "7.5.0",
    "helmet": "8.0.0",
    "ioredis": "5.4.2",
    "jsonwebtoken": "9.0.2",
    "multer": "^2.1.1",
    "nanoid": "3.3.8",
    "nats": "^2.29.3",
    "node-cron": "3.0.3",
    "pdfkit": "^0.15.2",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "prom-client": "^15.1.3",
    "qrcode": "^1.5.4",
    "razorpay": "^2.9.5",
    "resend": "4.0.1",
    "socket.io": "4.8.1",
    "speakeasy": "^2.0.0",
    "stripe": "17.5.0",
    "swagger-ui-express": "^5.0.1",
    "winston": "3.17.0",
    "zod": "3.24.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "2.4.6",
    "@types/cookie-parser": "1.4.8",
    "@types/cors": "2.8.17",
    "@types/express": "4.17.21",
    "@types/jsonwebtoken": "9.0.7",
    "@types/node": "22.10.5",
    "@types/node-cron": "3.0.11",
    "@types/pdfkit": "^0.17.6",
    "@types/qrcode": "^1.5.5",
    "@types/speakeasy": "^2.0.10",
    "@types/supertest": "^7.2.0",
    "@types/swagger-ui-express": "^4.1.8",
    "concurrently": "^9.1.2",
    "nodemon": "3.1.9",
    "prisma": "5.22.0",
    "supertest": "^7.2.2",
    "ts-node": "10.9.2",
    "typescript": "5.7.2",
    "vitest": "^4.1.7"
  }
}
